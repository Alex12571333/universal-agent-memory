# Obelisk Memory production environment
#
# Copy to .env.production and replace every secret before deployment.
# Any secret below can be supplied as KEY_FILE=/run/secrets/name instead of KEY.
# Direct KEY wins for local development; KEY_FILE is preferred for Docker/K8s/Vault/SOPS.

UAM_API_KEY=replace-with-a-long-random-secret
UAM_API_KEY_FILE=
# Optional scoped keys for native integrations.
# Format: name:secret:scope+scope,name2:secret2:scope
# Scopes: admin, operator, agent, read, write.
UAM_API_KEYS=openclaw:replace-openclaw-key:agent,hermes:replace-hermes-key:agent,operator:replace-operator-key:operator
UAM_API_KEYS_FILE=
# Non-secret authorization bindings keyed by the names in UAM_API_KEYS.
# The agent IDs must first be created through /v1/identities/provision.
UAM_API_PRINCIPAL_BINDINGS_JSON={"openclaw":{"tenant_id":"00000000-0000-0000-0000-000000000001","workspace_id":"00000000-0000-0000-0000-000000000002","agent_id":"00000000-0000-0000-0000-000000000010"},"hermes":{"tenant_id":"00000000-0000-0000-0000-000000000001","workspace_id":"00000000-0000-0000-0000-000000000002","agent_id":"00000000-0000-0000-0000-000000000020"}}
UAM_API_PRINCIPAL_BINDINGS_JSON_FILE=
UAM_REQUIRE_IDENTITY_BINDINGS=true

# Stable local identifiers. Keep unchanged for one deployment unless migrating.
UAM_SERVER_ID=00000000-0000-0000-0000-000000000001
UAM_PROJECT_ID=00000000-0000-0000-0000-000000000002

# Immutable build/deployment identity recorded in live release evidence.
UAM_VERSION=0.1.0
UAM_SOURCE_COMMIT=replace-with-release-git-sha
UAM_IMAGE_DIGEST=sha256:replace-with-64-hex-image-digest
UAM_DEPLOYMENT_ID=replace-with-deployment-id
UAM_BUILD_TIME=replace-with-iso-8601-build-time

# Public TLS endpoint when using deploy/reverse-proxy/docker-compose.caddy.yml.
UAM_PUBLIC_HOST=localhost
UAM_PUBLIC_EMAIL=

# Database identities used inside docker-compose.prod.yml. Each `*_FILE` path
# is a host-side secret file containing only a high-entropy password. Compose
# mounts it at the matching `/run/secrets/...` path. Never commit these files.
POSTGRES_DB=memory
POSTGRES_USER=memory_admin
POSTGRES_PASSWORD_FILE=/absolute/path/to/obelisk-secrets/postgres_password
UAM_APP_DB_USER=memory_app
UAM_APP_DB_PASSWORD_FILE=/absolute/path/to/obelisk-secrets/app_db_password

# API/context policy.
UAM_CONTEXT_BUDGET_TOKENS=131072
UAM_CONTEXT_PER_LAYER_LIMIT=1000
UAM_PRIVACY_ENABLED=true
UAM_PRIVACY_ACTION=redact
UAM_MEMORY_TEXT_ENCRYPTION=pgcrypto
# `all` encrypts every canonical memory row. For selective encryption use a
# comma-separated list: private,thread,team,workspace,organization.
UAM_MEMORY_TEXT_ENCRYPTION_SCOPES=all
UAM_MEMORY_TEXT_ENCRYPTION_KEY=replace-with-a-long-random-memory-text-key
UAM_MEMORY_TEXT_ENCRYPTION_KEY_FILE=

# Operator-held HMAC keys for tamper-evident exports/imports.
# Prefer an external secret manager for shared production deployments.
UAM_AUDIT_SIGNING_KEY=
UAM_AUDIT_SIGNING_KEY_FILE=
UAM_VAULT_SIGNING_KEY=
UAM_VAULT_SIGNING_KEY_FILE=
UAM_RELEASE_SIGNING_KEY=
UAM_RELEASE_SIGNING_KEY_FILE=
# Optional only when the explicit hosted OpenAI embedding profile is selected.
# Generic OpenAI-compatible gateways never inherit this vendor credential.
OPENAI_API_KEY=
OPENAI_API_KEY_FILE=

# Vector embeddings. Keep DIM exactly equal to the model output dimension.
UAM_QDRANT_COLLECTION=memory_items
# OpenAI-compatible means the API contract, not a provider lock-in. This profile
# can point at OpenAI, OpenRouter, LiteLLM, vLLM, llama.cpp, TEI or another
# compatible gateway by overriding base URL/model/dim/key.
UAM_EMBEDDING_PROVIDER=openai-compatible
UAM_EMBEDDING_MODEL=provider/embedding-model-id
UAM_EMBEDDING_DIM=1536
UAM_EMBEDDING_BASE_URL=https://embedding-gateway.example.com/v1
# Set true only for providers that accept OpenAI's optional `dimensions` field.
UAM_EMBEDDING_SEND_DIMENSIONS=false
UAM_EMBEDDING_API_KEY=
UAM_EMBEDDING_API_KEY_FILE=
# Production default: Qdrant stores vectors/filter metadata only; text is hydrated from PostgreSQL.
UAM_QDRANT_PAYLOAD_TEXT=false

# Memory reasoning LLM. This is not the embedding endpoint.
# It uses the OpenAI-compatible `/v1/chat/completions` contract, so the same
# config shape can point at OpenAI, OpenRouter, LiteLLM, vLLM, llama.cpp or
# another compatible gateway.
UAM_MEMORY_LLM_PROVIDER=openai-compatible
UAM_MEMORY_LLM_MODEL=provider/memory-model-id
UAM_MEMORY_LLM_BASE_URL=https://model-gateway.example.com/v1
UAM_MEMORY_LLM_API_KEY=
UAM_MEMORY_LLM_API_KEY_FILE=
UAM_MEMORY_LLM_TIMEOUT_SECONDS=60
UAM_MEMORY_LLM_TEMPERATURE=0.1
UAM_MEMORY_LLM_CONTEXT_TOKENS=131072
UAM_MEMORY_LLM_MAX_TOKENS=1600
# Optional provider-specific fields, for example:
# {"chat_template_kwargs":{"enable_thinking":false}}
UAM_MEMORY_LLM_EXTRA_BODY_JSON={}

# MinIO is internal by default. Replace before storing real backups/artifacts.
MINIO_ROOT_USER=obelisk-admin
MINIO_ROOT_PASSWORD=replace-with-a-long-random-minio-password
MINIO_ROOT_PASSWORD_FILE=
